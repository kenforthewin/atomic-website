---
/**
 * Animated logo for the header.
 * Sequence: center node pops → lines grow outward from center → arc draws →
 *           outer nodes pop at endpoints → "tomic" slides in
 */
---

<div class="animated-logo">
  <svg
    viewBox="0 0 342.2 100"
    xmlns="http://www.w3.org/2000/svg"
    class="logo-svg"
  >
    <defs>
      <mask id="nodeGaps" maskUnits="userSpaceOnUse">
        <rect width="342.2" height="100" fill="white"/>
        <circle cx="18.8" cy="62.4" r="7.2" fill="black"/>
        <circle cx="49.9" cy="46.8" r="7.2" fill="black"/>
        <circle cx="81.0" cy="42.0" r="7.2" fill="black"/>
        <circle cx="49.9" cy="80.0" r="7.2" fill="black"/>
        <circle cx="81.0" cy="78.8" r="7.2" fill="black"/>
      </mask>
    </defs>

    <!-- Lines and arc, masked for gaps. Each element animated individually. -->
    <g mask="url(#nodeGaps)">
      <!-- Arc: from bottom-center (49.9,80) around to right (81,42) -->
      <path class="anim-arc" d="M 49.9,80 A 32.6,32.6 0 1,1 81.0,42"
        stroke="#9333ea" stroke-width="5" stroke-linecap="round" fill="none"/>
      <!-- Line: center → left -->
      <line class="anim-line-left" x1="49.9" y1="46.8" x2="18.8" y2="62.4" stroke="#9333ea" stroke-width="5" stroke-linecap="round"/>
      <!-- Line: center → right -->
      <line class="anim-line-right" x1="49.9" y1="46.8" x2="81.0" y2="42" stroke="#9333ea" stroke-width="5" stroke-linecap="round"/>
      <!-- Line: center → bottom-center -->
      <line class="anim-line-down" x1="49.9" y1="46.8" x2="49.9" y2="80.0" stroke="#9333ea" stroke-width="5" stroke-linecap="round"/>
    </g>

    <!-- Right → bottom-right line: outside mask to avoid mobile Safari
         compositing bug with stroke-dasharray + mask. Both endpoints are
         covered by nodes so no gap masking needed. -->
    <line class="anim-line-right-down" x1="81.0" y1="42" x2="81.0" y2="78.8" stroke="#9333ea" stroke-width="5" stroke-linecap="round"/>

    <!-- Center node: appears first -->
    <circle class="anim-node-center" cx="49.9" cy="46.8" r="6" fill="#9333ea"/>
    <!-- Outer nodes: pop in as lines reach them -->
    <circle class="anim-node-left" cx="18.8" cy="62.4" r="6" fill="#9333ea"/>
    <circle class="anim-node-right" cx="81.0" cy="42.0" r="6" fill="#9333ea"/>
    <circle class="anim-node-bottom" cx="49.9" cy="80.0" r="6" fill="#9333ea"/>
    <circle class="anim-node-bottom-right" cx="81.0" cy="78.8" r="6" fill="#9333ea"/>

    <!-- "tomic" text -->
    <g class="anim-tomic">
      <g transform="translate(92.0,84.0) scale(0.09379,0.09379)">
        <path d="M 262,0 Q 219,0 188.0,-13.5 Q 157,-27 140.5,-58.5 Q 124,-90 124,-145 L 124,-444 L 36,-444 L 36,-504 L 124,-504 L 134,-621 L 194,-621 L 194,-503 L 345,-503 L 345,-444 L 194,-444 L 194,-145 Q 194,-95 214.0,-77.5 Q 234,-60 285,-60 L 337,-60 L 337,0 Z M 676,12 Q 607,12 551.5,-20.5 Q 496,-53 464.0,-112.5 Q 432,-172 432,-251 Q 432,-333 464.5,-392.0 Q 497,-451 553.0,-483.5 Q 609,-516 678,-516 Q 750,-516 805.0,-483.5 Q 860,-451 892.0,-392.0 Q 924,-333 924,-251 Q 924,-172 891.5,-112.5 Q 859,-53 803.5,-20.5 Q 748,12 676,12 Z M 677,-48 Q 724,-48 763.5,-71.0 Q 803,-94 827.5,-139.5 Q 852,-185 852,-252 Q 852,-320 828.0,-365.0 Q 804,-410 764.5,-432.5 Q 725,-455 678,-455 Q 633,-455 593.0,-432.0 Q 553,-409 528.5,-364.5 Q 504,-320 504,-252 Q 504,-185 528.0,-139.5 Q 552,-94 591.5,-71.0 Q 631,-48 677,-48 Z M 1044,0 L 1044,-504 L 1108,-504 L 1113,-428 L 1113,-428 Q 1136,-470 1177.0,-493.0 Q 1218,-516 1268,-516 Q 1306,-516 1337.5,-505.0 Q 1369,-494 1393.5,-472.0 Q 1418,-450 1432,-415 L 1432,-415 Q 1457,-462 1502.5,-489.0 Q 1548,-516 1600,-516 Q 1658,-516 1700.5,-493.0 Q 1743,-470 1767.0,-423.0 Q 1791,-376 1791,-304 L 1791,0 L 1721,0 L 1721,-296 Q 1721,-376 1688.0,-415.5 Q 1655,-455 1596,-455 Q 1556,-455 1523.0,-433.5 Q 1490,-412 1471.0,-371.5 Q 1452,-331 1452,-271 L 1452,0 L 1382,0 L 1382,-296 Q 1382,-376 1349.5,-415.5 Q 1317,-455 1258,-455 Q 1217,-455 1184.5,-433.5 Q 1152,-412 1133.0,-370.5 Q 1114,-329 1114,-268 L 1114,0 Z M 1933,0 L 1933,-504 L 2003,-504 L 2003,0 Z M 1968,-623 Q 1947,-623 1932.0,-637.5 Q 1917,-652 1917,-674 Q 1917,-697 1931.5,-710.5 Q 1946,-724 1968,-724 Q 1988,-724 2003.0,-710.5 Q 2018,-697 2018,-674 Q 2018,-652 2003.5,-637.5 Q 1989,-623 1968,-623 Z M 2376,12 Q 2306,12 2251.0,-21.0 Q 2196,-54 2164.0,-113.5 Q 2132,-173 2132,-251 Q 2132,-332 2164.0,-390.5 Q 2196,-449 2251.5,-482.5 Q 2307,-516 2376,-516 Q 2464,-516 2522.5,-470.5 Q 2581,-425 2597,-350 L 2527,-350 Q 2516,-400 2474.5,-427.5 Q 2433,-455 2375,-455 Q 2330,-455 2291.0,-432.5 Q 2252,-410 2228.0,-365.0 Q 2204,-320 2204,-251 Q 2204,-200 2218.0,-162.0 Q 2232,-124 2256.0,-98.5 Q 2280,-73 2311.0,-60.0 Q 2342,-47 2375,-47 Q 2413,-47 2444.5,-59.5 Q 2476,-72 2498.0,-96.0 Q 2520,-120 2527,-154 L 2597,-154 Q 2582,-81 2523.0,-34.5 Q 2464,12 2376,12 Z" fill="#1a1a1a"/>
      </g>
    </g>
  </svg>
</div>

<style>
  .animated-logo {
    height: 2rem;
    display: flex;
    align-items: center;
  }

  .logo-svg {
    height: 100%;
    width: auto;
    overflow: visible;
  }

  /* ---- Timing ----
     0.2s  — center node pops
     0.45s — lines grow outward from center + arc draws
     0.7s  — right→bottom-right line draws (cascading)
     0.75s — left, right, bottom nodes pop
     0.95s — bottom-right node pops
     1.1s  — "tomic" slides in
  */

  /* --- Center node pop --- */
  .anim-node-center {
    opacity: 0;
    transform-origin: 49.9px 46.8px;
    transform: scale(0);
    animation: node-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  }

  /* --- Lines grow from center outward --- */
  .anim-line-left {
    stroke-dasharray: 35;
    stroke-dashoffset: 35;
    animation: draw-line 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards;
  }
  .anim-line-right {
    stroke-dasharray: 32;
    stroke-dashoffset: 32;
    animation: draw-line 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards;
  }
  .anim-line-down {
    stroke-dasharray: 34;
    stroke-dashoffset: 34;
    animation: draw-line 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards;
  }
  .anim-line-right-down {
    stroke-dasharray: 37;
    stroke-dashoffset: 37;
    animation: draw-line 0.35s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }

  /* --- Arc draws --- */
  .anim-arc {
    stroke-dasharray: 150;
    stroke-dashoffset: 150;
    animation: draw-arc 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  @keyframes draw-arc {
    to { stroke-dashoffset: 0; }
  }

  /* --- Outer nodes pop in as lines reach them --- */
  .anim-node-left,
  .anim-node-right,
  .anim-node-bottom,
  .anim-node-bottom-right {
    opacity: 0;
    transform: scale(0);
    animation: node-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 0.75s forwards;
  }
  .anim-node-left         { transform-origin: 18.8px 62.4px; }
  .anim-node-right        { transform-origin: 81.0px 42.0px; }
  .anim-node-bottom       { transform-origin: 49.9px 80.0px; }
  .anim-node-bottom-right { transform-origin: 81.0px 78.8px; }

  @keyframes node-pop {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* --- "tomic" slides in --- */
  .anim-tomic {
    opacity: 0;
    transform: translateX(-8px);
    animation: tomic-slide 0.5s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }

  @keyframes tomic-slide {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
