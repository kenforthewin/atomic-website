---
import '../styles/global.css';
import AnimatedLogo from '../components/AnimatedLogo.astro';

interface Props {
  title: string;
  description?: string;
  dark?: boolean;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleAuthor?: string;
}

const {
  title,
  description = 'A personal knowledge base that turns freeform notes into a semantically-connected, AI-augmented knowledge graph.',
  dark = false,
  ogImage = '/social-preview.png',
  ogType = 'website',
  articlePublishedTime,
  articleAuthor,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();

let stars: number | null = null;
try {
  const res = await fetch('https://api.github.com/repos/kenforthewin/atomic', {
    headers: { 'Accept': 'application/vnd.github.v3+json' },
  });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number') stars = data.stargazers_count;
  }
} catch {}

const formatStars = (n: number) => n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n);
const starsLabel = stars !== null ? formatStars(stars) : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Atomic Blog" href="/rss.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Atomic" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class:list={['font-body antialiased', dark ? 'bg-[#1e1e1e] text-white' : 'bg-bg-primary text-text-primary']}>
    <nav class:list={['fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b', dark ? 'bg-[#252525]/90 border-[#2d2d2d]' : 'bg-bg-primary/80 border-border-light']}>
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center group">
          {dark ? <img src="/logo-dark.svg" alt="Atomic" class="h-6" /> : <AnimatedLogo />}
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-8">
          <a href="/getting-started/" class:list={['text-sm transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}>Docs</a>
          <a href="/blog" class:list={['text-sm transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}>Blog</a>
          <a href="/api/explorer" class:list={['text-sm transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}>API</a>
          <a
            href="https://github.com/kenforthewin/atomic"
            target="_blank"
            rel="noopener noreferrer"
            class:list={['group inline-flex items-center gap-2 text-sm transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}
          >
            <span>GitHub</span>
            <span
              class:list={[
                'inline-flex items-center gap-1 px-1.5 h-[1.375rem] text-[0.6875rem] leading-none rounded-full border transition-colors',
                dark ? 'border-[#2d2d2d] group-hover:border-[#3d3d3d]' : 'border-border group-hover:border-accent/30',
                !starsLabel && 'hidden',
              ]}
              data-stars-wrapper
            >
              <svg class="w-3 h-3 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
              </svg>
              <span class="tabular-nums font-medium" data-stars-label>{starsLabel}</span>
            </span>
          </a>
          <a
            href="https://github.com/kenforthewin/atomic/releases/latest"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-accent hover:bg-accent-dark rounded-lg transition-colors"
          >
            Download
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          class="md:hidden p-2 -mr-2"
          id="mobile-menu-toggle"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class:list={['w-5 h-5', dark ? 'text-gray-400' : 'text-text-secondary']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile dropdown -->
      <div class:list={['hidden md:hidden border-t', dark ? 'border-[#2d2d2d] bg-[#252525]' : 'border-border-light bg-bg-primary']} id="mobile-menu">
        <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
          <a href="/getting-started/" class:list={['text-sm py-1.5 transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}>Docs</a>
          <a href="/blog" class:list={['text-sm py-1.5 transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}>Blog</a>
          <a href="/api/explorer" class:list={['text-sm py-1.5 transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}>API</a>
          <a
            href="https://github.com/kenforthewin/atomic"
            target="_blank"
            rel="noopener noreferrer"
            class:list={['inline-flex items-center gap-1.5 text-sm py-1.5 transition-colors', dark ? 'text-gray-400 hover:text-white' : 'text-text-secondary hover:text-text-primary']}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            <span>GitHub</span>
            <span class:list={['inline-flex items-center gap-1 ml-1 px-1.5 py-0.5 text-xs rounded border', dark ? 'border-[#2d2d2d] bg-[#1e1e1e]' : 'border-border-light bg-bg-white/50', !starsLabel && 'hidden']} data-stars-wrapper>
              <svg class="w-3 h-3 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
              </svg>
              <span data-stars-label>{starsLabel}</span>
            </span>
          </a>
          <a
            href="https://github.com/kenforthewin/atomic/releases/latest"
            class="inline-flex items-center justify-center gap-2 px-4 py-2.5 mt-1 text-sm font-medium text-white bg-accent hover:bg-accent-dark rounded-lg transition-colors"
          >
            Download
          </a>
        </div>
      </div>
    </nav>

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        const open = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', String(!open));
      });

      fetch('https://api.github.com/repos/kenforthewin/atomic')
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          const n = data?.stargazers_count;
          if (typeof n !== 'number') return;
          const label = n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n);
          document.querySelectorAll('[data-stars-label]').forEach(el => {
            el.textContent = label;
          });
          document.querySelectorAll('[data-stars-wrapper]').forEach(el => {
            el.classList.remove('hidden');
          });
        })
        .catch(() => {});
    </script>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-border-light bg-bg-secondary">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div>
            <div class="mb-4">
              <img src="/logo.svg" alt="Atomic" class="h-5" />
            </div>
            <p class="text-sm text-text-muted leading-relaxed">
              Your ideas, semantically connected.
            </p>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-3">Product</h4>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><a href="https://github.com/kenforthewin/atomic/releases/latest" class="hover:text-text-primary transition-colors">Download</a></li>
              <li><a href="/getting-started/self-hosting/" class="hover:text-text-primary transition-colors">Self-Host</a></li>
              <li><a href="/guides/ios-app/" class="hover:text-text-primary transition-colors">iOS App</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-3">Resources</h4>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><a href="/getting-started/" class="hover:text-text-primary transition-colors">Documentation</a></li>
              <li><a href="/api/explorer" class="hover:text-text-primary transition-colors">API Reference</a></li>
              <li><a href="/blog" class="hover:text-text-primary transition-colors">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-3">Community</h4>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><a href="https://github.com/kenforthewin/atomic" class="hover:text-text-primary transition-colors">GitHub</a></li>
              <li><a href="https://github.com/kenforthewin/atomic/issues" class="hover:text-text-primary transition-colors">Issues</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 pt-6 border-t border-border-light text-sm text-text-muted">
          &copy; {new Date().getFullYear()} Atomic
        </div>
      </div>
    </footer>
  </body>
</html>
