---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="API Explorer — Atomic">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="mb-8">
      <h1 class="font-display text-3xl md:text-4xl tracking-tight mb-3">API Explorer</h1>
      <p class="text-text-secondary">
        Interactive reference for the Atomic REST API. All endpoints require Bearer token authentication.
      </p>
    </div>
    <div id="api-reference" class="rounded-xl overflow-hidden border border-border-light bg-bg-white min-h-[600px]">
      <p class="p-8 text-text-muted italic text-center">
        API explorer will be available once the OpenAPI spec is configured.
        <br />
        <a href="/api/overview/" class="text-accent hover:underline">View the API overview</a> in the meantime.
      </p>
    </div>
  </div>
</BaseLayout>
