---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiExplorer from '../../components/ApiExplorer.tsx';
---

<BaseLayout title="API Explorer — Atomic" dark>
  <div class="api-explorer-wrapper">
    <ApiExplorer client:only="react" />
  </div>
</BaseLayout>

<style is:global>
  .api-explorer-wrapper {
    padding-top: 1rem;
    max-width: 100vw;
    overflow-x: hidden;
  }

  /* Scalar injects its own layout — constrain it */
  .scalar-app {
    max-width: 100vw !important;
    overflow-x: hidden !important;
  }

  .scalar-api-reference {
    max-width: 100vw !important;
  }
</style>
