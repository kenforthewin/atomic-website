---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import canvasImg from '../assets/canvas.png';
import wikiImg from '../assets/wiki.png';
import searchImg from '../assets/search.png';
import atomImg from '../assets/atom.png';

let stars: number | null = null;
try {
  const repoRes = await fetch('https://api.github.com/repos/kenforthewin/atomic', {
    headers: { 'Accept': 'application/vnd.github.v3+json' },
  });
  if (repoRes.ok) {
    const data = await repoRes.json();
    if (typeof data.stargazers_count === 'number') stars = data.stargazers_count;
  }
} catch {}

const starsLabel = stars !== null
  ? (stars >= 1000 ? `${(stars / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(stars))
  : '';

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Atomic',
  description: 'A local-first personal knowledge base that turns freeform notes into a semantically-connected, AI-augmented knowledge graph.',
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'macOS, Windows, Linux, iOS',
  url: 'https://atomicapp.ai',
  downloadUrl: 'https://github.com/kenforthewin/atomic/releases/latest',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: 'Kenny Bergquist', url: 'https://github.com/kenforthewin' },
};

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Atomic',
  url: 'https://atomicapp.ai',
  logo: 'https://atomicapp.ai/logo.svg',
  sameAs: ['https://github.com/kenforthewin/atomic'],
};
---

<BaseLayout title="Atomic — A local-first knowledge graph">
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(softwareJsonLd)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(organizationJsonLd)}
  />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Subtle grid background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #1a1a1a 1px, transparent 0); background-size: 32px 32px;"></div>

    <!-- Decorative nodes -->
    <div class="absolute top-20 left-[4%] w-2 h-2 rounded-full bg-accent/20 animate-pulse"></div>
    <div class="absolute bottom-16 left-[6%] w-1.5 h-1.5 rounded-full bg-accent/15 animate-pulse" style="animation-delay: 0.5s;"></div>
    <div class="absolute top-16 right-[6%] w-2.5 h-2.5 rounded-full bg-accent/20 animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-40 right-[12%] w-1.5 h-1.5 rounded-full bg-accent/10 animate-pulse" style="animation-delay: 1.5s;"></div>
    <div class="absolute bottom-20 right-[8%] w-2 h-2 rounded-full bg-accent/15 animate-pulse" style="animation-delay: 2s;"></div>

    <!-- Connecting lines (SVG) -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none" xmlns="http://www.w3.org/2000/svg">
      <line x1="4%" y1="20%" x2="6%" y2="85%" stroke="#7c3aed" stroke-width="1" />
      <line x1="94%" y1="15%" x2="88%" y2="40%" stroke="#7c3aed" stroke-width="1" />
      <line x1="88%" y1="40%" x2="92%" y2="80%" stroke="#7c3aed" stroke-width="0.5" />
    </svg>

    <div class="max-w-7xl mx-auto px-6 pt-10 pb-10 md:pt-14 md:pb-12 relative">
      <div>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-balance mb-6">
          An AI-native knowledge graph <span class="italic">that's yours end-to-end.</span>
        </h1>

        <p class="text-lg md:text-xl text-text-secondary leading-relaxed max-w-3xl mb-10">
          Self-organizing notes with semantic search, wiki synthesis, and agentic chat — all open source. Run it as a desktop app, or self-host a server and sync every device. Your notes, your hardware, your model.
        </p>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <a
            href="https://github.com/kenforthewin/atomic/releases/latest"
            class="group inline-flex items-center gap-3 px-7 py-3.5 text-base font-medium text-white bg-accent hover:bg-accent-dark rounded-xl transition-all hover:shadow-lg hover:shadow-accent/20"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download for Mac
          </a>
          <a
            href="https://github.com/kenforthewin/atomic"
            class="group inline-flex items-center gap-3 pl-7 pr-5 py-3.5 text-base font-medium text-text-primary bg-bg-white border border-border rounded-xl hover:border-accent/30 hover:bg-accent-subtle/50 transition-all"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            <span>View on GitHub</span>
            <span
              class:list={['inline-flex items-center gap-1.5 pl-3 -mr-1 border-l border-border group-hover:border-accent/20 transition-colors', !starsLabel && 'hidden']}
              data-stars-wrapper
            >
              <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
              </svg>
              <span class="text-sm tabular-nums text-text-secondary" data-stars-label>{starsLabel}</span>
            </span>
          </a>
        </div>

        <p class="mt-4 text-xs text-text-muted">
          Also available as a <a href="/getting-started/self-hosting" class="underline underline-offset-2 hover:text-text-secondary transition-colors">self-hosted server</a> or <a href="/guides/ios-app/" class="underline underline-offset-2 hover:text-text-secondary transition-colors">iOS app</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Video showcase -->
  <section class="relative pb-16 md:pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/10 max-w-5xl mx-auto">
        <video
          autoplay
          muted
          loop
          playsinline
          poster="/images/screenshots/atomicdemo-poster.webp"
          class="w-full"
        >
          <source src="/atomicdemo.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-20 md:py-28 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight">
          What AI-native looks like
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Semantic Search</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Search by what you meant, not what you typed.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Wiki Synthesis</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Pick a tag. Get a wiki article — with citations back to the notes that wrote it.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Agentic Chat</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Chat with your notes. It cites them; it doesn't invent them.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Spatial Canvas</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            A force-directed map of your thinking. Related ideas drift toward each other on their own.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Auto-Tagging</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            No folders. Atomic tags every note the moment it lands.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">MCP Integration</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Plug it into Claude or Cursor. Your notes, in your agent's hands.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature screenshots -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Wiki -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <span class="text-xs font-medium tracking-wide uppercase text-text-muted mb-3 block">Wiki Synthesis</span>
          <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
            Wikis, written by your notes.
          </h2>
          <p class="text-text-secondary leading-relaxed mb-6">
            Pick any tag. Atomic generates a full wiki article from every note, clip, and saved page underneath — with inline citations back to the source atoms. Articles regenerate as you add more.
          </p>
          <a href="/concepts/wiki-synthesis/" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
            Learn more
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="rounded-xl overflow-hidden shadow-xl shadow-black/8">
          <Image src={wikiImg} alt="Wiki synthesis view" class="w-full" format="webp" quality={85} loading="lazy" />
        </div>
      </div>

      <!-- Search -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div class="order-2 lg:order-1 rounded-xl overflow-hidden shadow-xl shadow-black/8">
          <Image src={searchImg} alt="Semantic search view" class="w-full" format="webp" quality={85} loading="lazy" />
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-xs font-medium tracking-wide uppercase text-text-muted mb-3 block">Semantic Search</span>
          <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
            Search by meaning, not strings.
          </h2>
          <p class="text-text-secondary leading-relaxed mb-6">
            Atomic embeds every atom into vector space. Type a question; get back ideas — even when your notes don't use the words you searched for. Find a note from six months ago without remembering what you titled it.
          </p>
          <a href="/concepts/semantic-search/" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
            Learn more
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Atom -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-xs font-medium tracking-wide uppercase text-text-muted mb-3 block">Atoms</span>
          <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
            Everything is an atom.
          </h2>
          <p class="text-text-secondary leading-relaxed mb-6">
            Notes, articles, web clips — anything you save becomes an atom. Each one gets tagged, embedded, and connected the moment it lands. No folders, no schemas, nothing to maintain.
          </p>
          <a href="/concepts/atoms/" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
            Learn more
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="rounded-xl overflow-hidden shadow-xl shadow-black/8">
          <Image src={atomImg} alt="Single atom view" class="w-full" format="webp" quality={85} loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Daily Briefing spotlight -->
  <section class="relative pb-20 md:pb-28">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
          Your daily briefing
        </h2>
        <p class="text-text-secondary leading-relaxed">
          A summary of everything new in your graph. Click any citation; the source atom lights up on a mini-canvas.
        </p>
      </div>
      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/10">
        <video
          autoplay
          muted
          loop
          playsinline
          poster="/images/screenshots/daily-briefing-poster.jpg"
          class="w-full"
        >
          <source src="/daily-briefing.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <!-- Runs everywhere -->
  <section class="py-20 md:py-28 bg-bg-secondary">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
        One server. Every device.
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto mb-12">
        Your server is the source of truth. Every client points at it: desktop, iOS, browser, MCP. Run the whole stack on a laptop, or self-host and sync every device.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
        {[
          { label: 'macOS', icon: 'M3 4a1 1 0 011-1h16a1 1 0 011 1v12a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm4 16h10' },
          { label: 'iOS', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
          { label: 'Server', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
          { label: 'Extension', icon: 'M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z' },
          { label: 'MCP', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
        ].map(({ label, icon }) => (
          <div class="flex flex-col items-center gap-2 p-4">
            <div class="w-12 h-12 rounded-xl bg-bg-white border border-border-light flex items-center justify-center">
              <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <span class="text-sm text-text-secondary">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-10">
        Free. Open Source.<br />Yours end-to-end.
      </h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://github.com/kenforthewin/atomic/releases/latest"
