---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import atomImg from '../assets/atom.png';
import searchImg from '../assets/search.png';
import canvasImg from '../assets/canvas.png';
---

<BaseLayout title="Atomic — Shared Memory for You and Your AI">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Subtle grid background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #1a1a1a 1px, transparent 0); background-size: 32px 32px;"></div>

    <!-- Decorative nodes — memory-themed: two clusters converging -->
    <div class="absolute top-28 left-[8%] w-2 h-2 rounded-full bg-accent/20 animate-pulse"></div>
    <div class="absolute top-44 left-[12%] w-1.5 h-1.5 rounded-full bg-accent/15 animate-pulse" style="animation-delay: 0.3s;"></div>
    <div class="absolute top-36 left-[18%] w-1 h-1 rounded-full bg-accent/10 animate-pulse" style="animation-delay: 0.8s;"></div>
    <div class="absolute top-28 right-[8%] w-2 h-2 rounded-full bg-accent/20 animate-pulse" style="animation-delay: 0.5s;"></div>
    <div class="absolute top-44 right-[12%] w-1.5 h-1.5 rounded-full bg-accent/15 animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-36 right-[18%] w-1 h-1 rounded-full bg-accent/10 animate-pulse" style="animation-delay: 1.3s;"></div>

    <!-- Connecting lines converging to center -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none" xmlns="http://www.w3.org/2000/svg">
      <line x1="8%" y1="18%" x2="35%" y2="30%" stroke="#7c3aed" stroke-width="0.5" />
      <line x1="12%" y1="28%" x2="40%" y2="35%" stroke="#7c3aed" stroke-width="0.5" />
      <line x1="92%" y1="18%" x2="65%" y2="30%" stroke="#7c3aed" stroke-width="0.5" />
      <line x1="88%" y1="28%" x2="60%" y2="35%" stroke="#7c3aed" stroke-width="0.5" />
    </svg>

    <div class="max-w-6xl mx-auto px-6 pt-24 pb-16 md:pt-32 md:pb-24 relative">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 text-xs font-medium tracking-wide uppercase text-accent bg-accent-subtle rounded-full border border-accent/10">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
          MCP Server
        </div>

        <h1 class="font-display text-5xl md:text-7xl leading-[1.05] tracking-tight mb-6">
          Shared memory for<br />
          you and <span class="italic text-accent">your AI</span>
        </h1>

        <p class="text-lg md:text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto mb-10">
          Every conversation starts from scratch. When platforms add memory, it's a black box you can't see or control. Atomic is different — a shared knowledge base where both you and your agents read and write. You stay in control.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/guides/mcp-server/"
            class="group inline-flex items-center gap-3 px-7 py-3.5 text-base font-medium text-white bg-accent hover:bg-accent-dark rounded-xl transition-all hover:shadow-lg hover:shadow-accent/20"
          >
            Get started
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="https://github.com/kenforthewin/atomic"
            class="inline-flex items-center gap-2 px-7 py-3.5 text-base font-medium text-text-primary bg-bg-white border border-border rounded-xl hover:border-accent/30 hover:bg-accent-subtle/50 transition-all"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Loop -->
  <section class="py-20 md:py-28 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
          A feedback loop, not a <span class="italic">black box</span>
        </h2>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">
          Both you and your AI agents contribute to the same knowledge base. What one writes, the other can find.
        </p>
      </div>

      <!-- Step 1 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-full bg-accent text-white flex items-center justify-center text-sm font-semibold">1</div>
            <span class="text-xs font-medium tracking-wide uppercase text-accent">Remember</span>
          </div>
          <h3 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
            Your agents <span class="italic">remember</span>
          </h3>
          <p class="text-text-secondary leading-relaxed">
            They store what they learn via MCP. Preferences, decisions, project context — anything worth retaining across conversations. Knowledge accumulates automatically.
          </p>
        </div>
        <div class="rounded-xl overflow-hidden shadow-xl shadow-black/8">
          <Image src={atomImg} alt="Atoms created by AI agents in Atomic" class="w-full" format="webp" quality={85} loading="lazy" />
        </div>
      </div>

      <!-- Step 2 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div class="order-2 lg:order-1 rounded-xl overflow-hidden shadow-xl shadow-black/8">
          <Image src={searchImg} alt="Curating and editing knowledge in Atomic" class="w-full" format="webp" quality={85} loading="lazy" />
        </div>
        <div class="order-1 lg:order-2">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-full bg-accent text-white flex items-center justify-center text-sm font-semibold">2</div>
            <span class="text-xs font-medium tracking-wide uppercase text-accent">Curate</span>
          </div>
          <h3 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
            You <span class="italic">curate</span>
          </h3>
          <p class="text-text-secondary leading-relaxed">
            See everything your agents stored. Edit, organize, add your own knowledge. Shape what they know. You're not monitoring a black box — you're actively shaping your agent's context.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-full bg-accent text-white flex items-center justify-center text-sm font-semibold">3</div>
            <span class="text-xs font-medium tracking-wide uppercase text-accent">Shared</span>
          </div>
          <h3 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
            One knowledge base, <span class="italic">two contributors</span>
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Agents search before answering. You browse and enrich. Both sides draw from the same source — what one writes, the other can find.
          </p>
        </div>
        <div class="rounded-xl overflow-hidden shadow-xl shadow-black/8">
          <Image src={canvasImg} alt="Connected knowledge graph in Atomic canvas view" class="w-full" format="webp" quality={85} loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 4 Tools -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
          Four tools. That's the <span class="italic">entire API</span>.
        </h2>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">
          Atomic exposes a minimal MCP surface. No bloat, no complexity. Agents get exactly what they need.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-4xl mx-auto">
        <!-- semantic_search -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-accent-subtle flex items-center justify-center">
              <svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
              </svg>
            </div>
            <code class="font-mono text-sm font-medium text-text-primary">semantic_search</code>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Search memory for relevant knowledge before responding
          </p>
        </div>

        <!-- read_atom -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-accent-subtle flex items-center justify-center">
              <svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <code class="font-mono text-sm font-medium text-text-primary">read_atom</code>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Read the full content of a specific memory
          </p>
        </div>

        <!-- create_atom -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-accent-subtle flex items-center justify-center">
              <svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </div>
            <code class="font-mono text-sm font-medium text-text-primary">create_atom</code>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Remember something new worth retaining
          </p>
        </div>

        <!-- update_atom -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-accent-subtle flex items-center justify-center">
              <svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182" />
              </svg>
            </div>
            <code class="font-mono text-sm font-medium text-text-primary">update_atom</code>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Revise existing knowledge when it's gone stale
          </p>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="/guides/mcp-server/" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
          See setup instructions for Claude Code, Cursor, and more
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Works with -->
  <section class="py-20 md:py-28 bg-bg-secondary">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
        Works with every <span class="italic">MCP client</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto mb-12">
        Standard Model Context Protocol over Streamable HTTP. Connect any agent that speaks MCP.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
        {['Claude Code', 'Claude Desktop', 'Cursor', 'Windsurf', 'Any MCP Client'].map((name) => (
          <div class="px-5 py-3 bg-bg-white border border-border-light rounded-xl text-sm font-medium text-text-secondary">
            {name}
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/guides/mcp-server/" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
          View setup guide for each client
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- You stay in control -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
          Your memory, <span class="italic">your rules</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- See everything -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">See everything</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Browse what your agents remember. Canvas view shows connections. Search finds anything.
          </p>
        </div>

        <!-- Edit and enrich -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Edit and enrich</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Add notes, articles, and context your agents can discover. Curate what they've stored. Delete what doesn't belong.
          </p>
        </div>

        <!-- Self-hosted -->
        <div class="group p-6 bg-bg-white rounded-xl border border-border-light hover:border-accent/20 transition-all hover:shadow-md">
          <div class="w-10 h-10 rounded-lg bg-accent-subtle flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="font-medium text-lg mb-2">Self-hosted</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Runs on your machine or your server. Open source. Your data never leaves your infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-bg-secondary">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-6">
        Give your AI agents<br /><span class="italic text-accent">memory</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto mb-8">
        Open source. Self-hosted. You stay in control.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/guides/mcp-server/"
          class="inline-flex items-center gap-3 px-7 py-3.5 text-base font-medium text-white bg-accent hover:bg-accent-dark rounded-xl transition-all hover:shadow-lg hover:shadow-accent/20"
        >
          Read the MCP guide
        </a>
        <a
          href="https://github.com/kenforthewin/atomic"
          class="inline-flex items-center gap-2 px-7 py-3.5 text-base font-medium text-text-primary bg-bg-white border border-border rounded-xl hover:border-accent/30 transition-all"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section:first-of-type > div:last-child > div {
    animation: fade-in-up 0.8s ease-out;
  }
</style>
